# Draw a simple banner
clear 
setup_ui
print_logo

# Create data file if it doesn't exist
if [[ ! -f "$ENCRYPTED_FILE" ]]; then
    if [[ -f "$PASSWORD_FILE" ]] && [[ -s "$PASSWORD_FILE" ]]; then
        echo "Found existing plaintext passwords!"
        read -p "Enter a master password to encrypt existing data: " -s MASTER_PASSWORD
        echo
        encrypt_file
        echo "Existing passwords have been encrypted."
    else
        echo "Welcome to BashPass! Let's set up your master password."
        while true; do
            read -p "Create a master password: " -s MASTER_PASSWORD
            echo
            read -p "Confirm master password: " -s MASTER_PASSWORD_CONFIRM
            echo
            if [[ "$MASTER_PASSWORD" == "$MASTER_PASSWORD_CONFIRM" ]]; then
                echo "Master password set successfully!"
                break
            else
                echo "Passwords don't match. Please try again."
            fi
        done
        echo "$STORE_HEADER" > "$PASSWORD_FILE"
        encrypt_file
        rm -f "$PASSWORD_FILE"
        echo "Your password vault is now encrypted!"
    fi
else
    echo "Encrypted password store detected!"
fi

main_menu() {
    prompt_master_password
    trap cleanup EXIT
    while true; do
        clear
        print_logo
        render_hacker_dashboard
        echo
        printf "%broot@bashpass%b:%b~/vault%b$ " "$C_PROMPT" "$C_RESET" "$C_DIM" "$C_RESET"
        read -r choice
        case "$choice" in
            1)
                ui_section "Generate or Update"
                upsert_password
                pause_for_user
                ;;
            2)
                ui_section "Add Custom Password"
                save_custom_password
                pause_for_user
                ;;
            3)
                ui_section "Saved Passwords"
                view_passwords
                pause_for_user
                ;;
            4)
                ui_section "Search Vault"
                search_passwords
                pause_for_user
                ;;
            5)
                ui_section "Delete Password"
                delete_password
                pause_for_user
                ;;
            6)
                ui_section "Service List"
                list_services
                pause_for_user
                ;;
            7)
                ui_section "Copy Password"
                copy_password
                pause_for_user
                ;;
            8)
                printf "%bBye!%b\n" "$C_OK" "$C_RESET"
                break
                ;;
            *)
                printf "%bInvalid command. Use 1-8.%b\n" "$C_WARN" "$C_RESET"
                pause_for_user
                ;;
        esac
    done
}

main_menu
